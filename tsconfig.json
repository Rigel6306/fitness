{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
     "typeRoots": ["./node_modules/@types", "./types"],
      "jsx": "react-native",
    "strict": false,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
, "app/index.jsx"  ]
,
"rules": {
  "react/jsx-uses-react": "off",
  "react/react-in-jsx-scope": "off"
}
}
